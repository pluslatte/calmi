    "@tabler/icons-react": "^3.34.1",
    "@tanstack/react-query": "^5.84.1",
    "date-fns": "^4.1.0",
    "immer": "^10.1.1",
    "mfm-js": "^0.25.0",
    "misskey-js": "2025.8.0-alpha.4",
    "next": "15.4.5",
    "next-auth": "5.0.0-beta.28",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-virtuoso": "^4.13.0",
